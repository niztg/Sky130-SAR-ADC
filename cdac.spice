* 10-bit binary-weighted CDAC
* Ports:
*   vdac     — top plate (connects to comparator VIN1/VIN2)
*   cdac_sw9..cdac_sw0 — switch control from SAR logic (1=vref, 0=gnd)
*   vref     — reference voltage (1.8V)
*   vdd      — supply (1.8V)
*   gnd      — ground

.subckt cdac vdac cdac_sw9 cdac_sw8 cdac_sw7 cdac_sw6 cdac_sw5
+            cdac_sw4 cdac_sw3 cdac_sw2 cdac_sw1 cdac_sw0
+            vref vdd gnd

.param C_unit = 25e-15

* --- Capacitor array ---
* Top plate = vdac, bottom plate = bpN
C9    vdac bp9  'C_unit * 512'
C8    vdac bp8  'C_unit * 256'
C7    vdac bp7  'C_unit * 128'
C6    vdac bp6  'C_unit * 64'
C5    vdac bp5  'C_unit * 32'
C4    vdac bp4  'C_unit * 16'
C3    vdac bp3  'C_unit * 8'
C2    vdac bp2  'C_unit * 4'
C1    vdac bp1  'C_unit * 2'
C0    vdac bp0  'C_unit * 1'
Cterm vdac gnd  'C_unit * 1'

* --- Bottom plate switches ---
* MSW_ref: connects bpN to vref when cdac_swN=1
* MSW_gnd: connects bpN to gnd  when cdac_swN=0 (gate driven by inverted signal)

* Bit 9
XMSW9_ref  bp9  cdac_sw9   vref gnd sky130_fd_pr__nfet_01v8 L=0.15 W=1 nf=1 ad='int((nf+1)/2) * W/nf * 0.29' as='int((nf+2)/2) * W/nf * 0.29' pd='2*int((nf+1)/2) * (W/nf + 0.29)' ps='2*int((nf+2)/2) * (W/nf + 0.29)' nrd='0.29 / W' nrs='0.29 / W' sa=0 sb=0 sd=0 mult=1
XMSW9_gnd  bp9  cdac_sw9_n gnd  gnd sky130_fd_pr__nfet_01v8 L=0.15 W=1 nf=1 ad='int((nf+1)/2) * W/nf * 0.29' as='int((nf+2)/2) * W/nf * 0.29' pd='2*int((nf+1)/2) * (W/nf + 0.29)' ps='2*int((nf+2)/2) * (W/nf + 0.29)' nrd='0.29 / W' nrs='0.29 / W' sa=0 sb=0 sd=0 mult=1


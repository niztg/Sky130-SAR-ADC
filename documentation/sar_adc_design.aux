\newlabel{subsection:nwell}{{4.3}{15}{The n-well bootstrap bug}{subsection.4.3}{}}
\@writefile{toc}{\contentsline {paragraph}{Symptom.}{15}{section*.14}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Wrong hypothesis first.}{15}{section*.15}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Falsified by charge balance.}{16}{section*.16}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Root cause: forward-biased PMOS body diode.}{16}{section*.17}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Fix.}{16}{section*.18}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Bootstrapped switch output at $V_\mathrm  {in}=1.5$\,V before and after the n-well fix. Pre-fix (red): the forward-biased body diode clamps the boost node, limiting \texttt  {VOUT} to $\approx 1.40$\,V with a $\sim $450\,ns settling tail into the second sample window. Post-fix (blue): \texttt  {VOUT} reaches $V_\mathrm  {in}$ within the first sample window. Shaded regions indicate the sampling phase.}}{17}{figure.caption.19}\protected@file@percent }
\newlabel{fig:bootstrap_fix_waveform}{{8}{17}{Bootstrapped switch output at $V_\mathrm {in}=1.5$\,V before and after the n-well fix. Pre-fix (red): the forward-biased body diode clamps the boost node, limiting \texttt {VOUT} to $\approx 1.40$\,V with a $\sim $450\,ns settling tail into the second sample window. Post-fix (blue): \texttt {VOUT} reaches $V_\mathrm {in}$ within the first sample window. Shaded regions indicate the sampling phase}{figure.caption.19}{}}
\@writefile{toc}{\contentsline {paragraph}{Result.}{17}{section*.20}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Bulk connection for the bootstrapped-switch PMOS XQ1. \textbf  {(a)}~Original design: bulk tied to the fixed VDD rail. During the hold phase X and net3 boost above VDD; the source/bulk p-n junction forward-biases and bleeds charge into the supply rail, clamping net3 to $\approx 2.5\,$V and collapsing the bootstrap voltage. \textbf  {(b)}~Fix: bulk re-routed to the floating \texttt  {nwell\_switch} bias node (net4). XXWA and XXWB are cross-coupled PMOS source-followers that drive net4 to $\max (\mathrm  {VDD},\,X)$, maintaining reverse bias on the junction throughout the clock cycle. An identical fix is applied to the bulk of XQ2.}}{17}{figure.caption.21}\protected@file@percent }
\newlabel{fig:nwell_fix}{{9}{17}{Bulk connection for the bootstrapped-switch PMOS XQ1. \textbf {(a)}~Original design: bulk tied to the fixed VDD rail. During the hold phase X and net3 boost above VDD; the source/bulk p-n junction forward-biases and bleeds charge into the supply rail, clamping net3 to $\approx 2.5\,$V and collapsing the bootstrap voltage. \textbf {(b)}~Fix: bulk re-routed to the floating \texttt {nwell\_switch} bias node (net4). XXWA and XXWB are cross-coupled PMOS source-followers that drive net4 to $\max (\mathrm {VDD},\,X)$, maintaining reverse bias on the junction throughout the clock cycle. An identical fix is applied to the bulk of XQ2}{figure.caption.21}{}}
